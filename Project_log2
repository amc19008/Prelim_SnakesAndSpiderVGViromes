#IsoPull
#!/bin/bash

# RNA + paired-end only version of your pipeline
# Fastp → BBNorm → SPAdes RNA
# 2 threads for fastp & bbnorm, 4 threads for spades

sralist="snsSRAs.csv"
meta="SnakeNspiderSRAs.csv"

# Confirm SRA list is present
if [[ $(ls | grep -xc "$sralist") -eq 1 ]]; then
    echo "Rad, the sra's present."
else
    echo "Radn't, SRA list not found in current wd. ):" 
    exit 1
fi

echo "Alright, file present. Let's get it started in here."

# Main loop
for x in $(cat "$sralist")
do
    echo "LOOP STARTING ----------------------------------------------------------------------------------------------------------------------------------------------------------"
    echo "Downloading $x at $(date)"

    export TMPDIR=/Users/maddlab_apollo365/Asherc/Prelim_Data_SNS/temp
        prefetch $x
    # Download paired-end files
    fasterq-dump -p -e 2 --split-files "$x"

    echo "Checking download for $x ..."

    if [[ $(ls | grep -c "${x}_1.fastq") -eq 1 ]] && [[ $(ls | grep -c "${x}_2.fastq") -eq 1 ]]; then

        echo "ALRIGHT FILES ARE THERE AND WE'LL MOVE FORWARD (˶ᵔ ᵕ ᵔ˶) ++++++++++++++++++___++++++++++++++++++++____+++++++++++++++++++++++++++++++++++___++++++++++++++++++++____+++++++++++++++++"

        R1="${x}_1.fastq"
        R2="${x}_2.fastq"

        echo "Cleaning raw reads with fastp...₊˚⊹♡"

        fastp -i "$R1" -I "$R2" -o "${x}_1_cln.fastq" -O "${x}_2_cln.fastq" --average_qual 25 -q 20 -l 50 -y -Y 30 -g -x -n 2 -c --overrepresentation_analysis --html "${x}.fastp.html" --json "${x}.fastp.json" --thread 2

        echo "!!FastP done, cleaning up raw reads...(*ᴗ͈ˬᴗ͈)"

        rm "$R1" "$R2"

        # Check that cleaned files have data
        if [[ $(wc -l "${x}_1_cln.fastq" | awk '{print $1}') -eq 0 ]]; then
            echo "$x failed QC (ᵕ—^—)"
            echo "$x" >> FailedQC.list
            rm "${x}_1_cln.fastq" "${x}_2_cln.fastq"
            continue
        fi

        echo "Reads look good, normalization time ⋆˙⟡"

        # BBNorm paired-end normalization
        bbnorm.sh in1="${x}_1_cln.fastq" in2="${x}_2_cln.fastq" out1="${x}.norm.R1.fq.gz" out2="${x}.norm.R2.fq.gz" target=100 min=1 threads=2 -eoom

        echo "!!Normalization done, removing unnormalized cleaned reads..."
        rm "${x}_1_cln.fastq" "${x}_2_cln.fastq"

        echo "Starting SPAdes RNA assembly..."

        spades.py --rna -1 "${x}.norm.R1.fq.gz" -2 "${x}.norm.R2.fq.gz" -t 4 -m 250 -o "${x}_spades"

        # Tar output and clean
        tar -czvf "${x}_spades.tar.gz" "${x}_spades"
        rm -r "${x}_spades"

        echo "Assembly finished!! Cleaning normed reads..."
        rm "${x}.norm.R1.fq.gz" "${x}.norm.R2.fq.gz"

        echo "Everything is completed for $x ⊹₊ ˚‧︵‿₊୨୧₊‿︵‧ ˚ ₊⊹ "
    else
        echo "$x failed download (ᵕ—^—)" | tee -a failed_downloads.out
    fi

    # Clean temp
    if [[ $(ls | grep -c "tmp") -gt 0 ]]; then
        rm -r *tmp*
    fi

    echo "LOOP DONE %ᵕ‿‿ᵕ%----------------------------------------------------------------------------------------------------------------------------------------------------------"

done

